# Copy this file to `.env.local` and fill in your values.
# Both consumer key and secret are needed for the WooCommerce REST API.
# Read-only credentials are sufficient for this site.

# ─── English (default) source ─────────────────────────────────────────
WOOCOMMERCE_STORE_URL=https://your-store.example.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional: Slovenian product data ────────────────────────────────
# Pick ONE of the two patterns below. The migration script will read
# Slovenian names + descriptions and bake `name_sl` / `shortDescription_sl`
# fields into lib/products.json so the EN/SL toggle switches product copy.
#
# Pattern A — separate Slovenian store (e.g. amareen.si vs amareen.eu):
# WOOCOMMERCE_STORE_URL_SL=https://www.amareen.si
# WOOCOMMERCE_CONSUMER_KEY_SL=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOOCOMMERCE_CONSUMER_SECRET_SL=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Pattern B — same store with WPML/Polylang (sends ?lang=sl):
# WOOCOMMERCE_LANG_PARAM_SL=sl

# ─── Stripe ───────────────────────────────────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
# Live keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Signing secret from the webhook endpoint you create at
# https://dashboard.stripe.com/test/webhooks (events: checkout.session.completed)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── GLS Slovenia (myGLS API) ─────────────────────────────────────────
# Docs: https://api.mygls.si/   (PDF: docs/MyGLS_API.pdf)
# Username + password from your myGLS portal account.
# ClientNumber from your GLS contract.
GLS_API_BASE=https://api.mygls.si
GLS_USERNAME=your@email.com
GLS_PASSWORD=your-password
GLS_CLIENT_NUMBER=12345678
GLS_WEBSHOP_ENGINE=YourShop

# Sender / pickup address (printed on every label)
GLS_SENDER_NAME=Your Company d.o.o.
GLS_SENDER_STREET=Street Name
GLS_SENDER_HOUSE_NUMBER=12
GLS_SENDER_HOUSE_NUMBER_INFO=
GLS_SENDER_CITY=City
GLS_SENDER_ZIP=1000
GLS_SENDER_COUNTRY=SI
GLS_SENDER_CONTACT_NAME=Contact Person
GLS_SENDER_CONTACT_PHONE=+386...
GLS_SENDER_CONTACT_EMAIL=contact@example.com

# ─── Bank transfer (UPN QR) + COD ─────────────────────────────────────
# Used to generate the UPN QR code shown on the order page and to compute
# the cash-on-delivery surcharge.
ELORIA_BANK_ACCOUNT_NAME=Your Company d.o.o.
ELORIA_BANK_IBAN=SIxxxxxxxxxxxxxxxxxxx
ELORIA_BANK_BIC=XXXXSI2X
ELORIA_BANK_NAME=Your Bank d.d.
ELORIA_COD_SURCHARGE_EUR=2.00

# ─── Email (Resend) ───────────────────────────────────────────────────
# Order confirmation (to customer) + new-order alert (to shop).
# API key from https://resend.com/api-keys ; verify your sending domain first.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# "From" must use a domain you verified in Resend.
EMAIL_FROM=Eloria <hello@amareen.si>
# Where new-order alerts are sent.
ADMIN_ORDER_EMAIL=hello@amareen.si
# Public site URL — used to build tracking links inside emails.
ELORIA_SITE_URL=https://eloria.si
